# iCAN Bazel Configuration

# Enable bzlmod
common --enable_bzlmod=true


# Disk cache
build --disk_cache=~/.cache/bazel-disk

# Device-only builds (no simulator — DriverKit requires real hardware)
build --ios_multi_cpus=arm64

# Convenience: show test output
test --test_output=errors

# DriverKit configuration
build:driverkit --define=DRIVERKIT_SDK=1

# Debug configuration
build:dbg --compilation_mode=dbg
build:opt --compilation_mode=opt
