#!/bin/bash
# Pre-commit hook: Prevent accidental commits of sensitive local config
# Activated by scripts/setup.sh (git config core.hooksPath .githooks)
#
# 1. Blocks commits of local config .bzl files (should be gitignored)
# 2. Blocks commits of .mobileprovision files
# 3. Blocks staged local absolute paths and usernames
# 4. Normalizes hardcoded team IDs in .pbxproj files

set -euo pipefail

# --- Block local config .bzl files ---
if git diff --cached --name-only | grep -Eq '(team_config|device_config)\.bzl$'; then
    echo "error: local config .bzl files must not be committed" >&2
    echo "       Add it to .gitignore if not already present." >&2
    exit 1
fi

# --- Block .mobileprovision ---
if git diff --cached --name-only | grep -q '\.mobileprovision$'; then
    echo "error: .mobileprovision files must not be committed" >&2
    exit 1
fi

# --- Block local absolute paths and usernames ---
repo_root="$(git rev-parse --show-toplevel)"
"$repo_root/scripts/check_private_paths.sh" --cached

# --- Normalize DEVELOPMENT_TEAM in pbxproj ---
while IFS= read -r -d '' pbxproj; do
    modified=false
    tmpfile="$(mktemp)"
    cp "$pbxproj" "$tmpfile"

    if grep -q 'DEVELOPMENT_TEAM = ' "$tmpfile" && grep -v '\$(DEVELOPMENT_TEAM)' "$tmpfile" | grep -q 'DEVELOPMENT_TEAM = '; then
        echo "Normalizing DEVELOPMENT_TEAM to variable in $pbxproj"
        if ! sed 's/DEVELOPMENT_TEAM = "[^$][^"]*";/DEVELOPMENT_TEAM = "$(DEVELOPMENT_TEAM)";/g; s/DEVELOPMENT_TEAM = [^"$][^";]*;/DEVELOPMENT_TEAM = "$(DEVELOPMENT_TEAM)";/g' "$tmpfile" > "$tmpfile.new"; then
            echo "Error: failed to normalize DEVELOPMENT_TEAM in $pbxproj" >&2
            rm -f "$tmpfile" "$tmpfile.new"
            exit 1
        fi
        if ! mv "$tmpfile.new" "$tmpfile"; then
            echo "Error: failed to update temporary file for $pbxproj" >&2
            rm -f "$tmpfile" "$tmpfile.new"
            exit 1
        fi
        modified=true
    fi

    if [ "$modified" = true ]; then
        if mv "$tmpfile" "$pbxproj"; then
            git add "$pbxproj"
        else
            echo "Error: failed to update $pbxproj" >&2
            rm -f "$tmpfile" "$tmpfile.new"
            exit 1
        fi
    else
        rm -f "$tmpfile" "$tmpfile.new"
    fi
done < <(git diff --cached --name-only -z -- '*.pbxproj')
